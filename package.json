{
  "name": "taluxa",
  "private": true,
  "version": "1.0.0",
  "description": "Windows desktop media player",
  "author": "Taluxa contributors",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:dev-port": "node scripts/devServerPort.check.mjs",
    "test:dev-bootstrap": "node scripts/devDependencyBootstrap.check.mjs",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.2.3",
    "electron-builder": "^24.13.3",
    "jsdom": "^25.0.1",
    "msw": "^2.4.11",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.taluxa.player",
    "productName": "Taluxa",
    "icon": "sources/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "sources/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/mpv/windows-x64",
        "to": "vendor/mpv/windows-x64",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "sources/icon.png",
      "signAndEditExecutable": false
    }
  }
}
